<TaskerData sr="" dvi="1" tv="6.3.13">

    <Project sr="proj0" ve="2">
        <cdate>1709500000000</cdate>
        <id>1</id>
        <nme>SMS Weather Responder</nme>
        <pids>10</pids>
        <tids>11</tids>
    </Project>

    <!-- ======================================================== -->
    <!-- PROFILE: Trigger on any incoming SMS                      -->
    <!-- ======================================================== -->
    <Profile sr="prof0" ve="2">
        <cdate>1709500000000</cdate>
        <edate>1709500000000</edate>
        <id>10</id>
        <mid0>11</mid0>
        <nme>SMS Weather Auto-Responder</nme>
        <Event sr="con0" ve="2">
            <code>7</code>
            <pri>0</pri>
            <Int sr="arg0" val="0"/>
            <Str sr="arg1" ve="3"></Str>
            <Str sr="arg2" ve="3"></Str>
        </Event>
    </Profile>

    <!-- ======================================================== -->
    <!-- TASK: Fetch Weather from NAIPS and Reply via SMS           -->
    <!-- NOTE: After importing, open Action 3 (JavaScriptlet) and  -->
    <!-- paste the contents of weather_fetch_naips.js into it.     -->
    <!-- Then set your NAIPS credentials at the top of the script. -->
    <!-- ======================================================== -->
    <Task sr="task0" ve="2">
        <cdate>1709500000000</cdate>
        <edate>1709500000000</edate>
        <id>11</id>
        <nme>Fetch Weather and Reply</nme>

        <!-- Action 1: Variable Set — Copy %SMSRB to %sms_body -->
        <Action sr="act0" ve="7">
            <code>547</code>
            <Str sr="arg0" ve="3">%sms_body</Str>
            <Str sr="arg1" ve="3">%SMSRB</Str>
            <Int sr="arg2" val="0"/>
            <Int sr="arg3" val="0"/>
            <Int sr="arg4" val="0"/>
            <Int sr="arg5" val="0"/>
        </Action>

        <!-- Action 2: Variable Set — Copy %SMSRF to %sms_from -->
        <Action sr="act1" ve="7">
            <code>547</code>
            <Str sr="arg0" ve="3">%sms_from</Str>
            <Str sr="arg1" ve="3">%SMSRF</Str>
            <Int sr="arg2" val="0"/>
            <Int sr="arg3" val="0"/>
            <Int sr="arg4" val="0"/>
            <Int sr="arg5" val="0"/>
        </Action>

        <!-- Action 3: JavaScriptlet — NAIPS SOAP Weather Fetch    -->
        <!-- PASTE contents of weather_fetch_naips.js here         -->
        <Action sr="act2" ve="7">
            <code>664</code>
            <Str sr="arg0" ve="3"><![CDATA[// PASTE the contents of weather_fetch_naips.js here
// Then replace YOUR_USERNAME_HERE and YOUR_PASSWORD_HERE
// with your NAIPS credentials.
flash("Please paste weather_fetch_naips.js code into this JavaScriptlet action");
setLocal("valid", "0");
setLocal("reply", "");]]></Str>
            <Str sr="arg1" ve="3"></Str>
            <Int sr="arg2" val="45"/>
        </Action>

        <!-- Action 4: If %valid equals 1 -->
        <Action sr="act3" ve="7">
            <code>35</code>
            <Str sr="arg0" ve="3">%valid</Str>
            <Int sr="arg1" val="2"/>
            <Str sr="arg2" ve="3">1</Str>
            <Str sr="arg3" ve="3"></Str>
        </Action>

        <!-- Action 5: Send SMS — Reply to sender with weather -->
        <Action sr="act4" ve="7">
            <code>37</code>
            <Str sr="arg0" ve="3">%sms_from</Str>
            <Str sr="arg1" ve="3">%reply</Str>
            <Int sr="arg2" val="0"/>
        </Action>

        <!-- Action 6: End If -->
        <Action sr="act5" ve="7">
            <code>36</code>
        </Action>

    </Task>

</TaskerData>
